// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "ssh_connections": [
    {
      "host": "github.com",
      "projects": []
    }
  ],
  "edit_predictions": {
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null
    },
    "enabled_in_text_threads": false
  },
  "features": {
    "edit_prediction_provider": "zed"
  },
  "icon_theme": "Catppuccin Latte",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "ui_font_family": "Zed Plex Mono",
  "buffer_font_family": "Zed Plex Mono",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Mocha"
  },
  "autosave": "on_focus_change",
  "format_on_save": "prettier",
  "enable_language_server": true,
  "completions": {
    "enabled": false
  },
  "soft_wrap": "editor_width",
  "inlay_hints": {
    "enabled": true,
    "trigger_chars": ["."]
  },
  "show_edit_predictions": false,
  "languages": {
    "Dockerfile": {
      "prettier": {
        "allowed": false
      }
    },
    "Plain Text": {
      "prettier": {
        "allowed": false
      }
    },
    "Diff": {
      "prettier": {
        "allowed": false
      }
    },
    "Markdown": {
      "format_on_save": "off",
      "prettier": {
        "allowed": false
      }
    },
    "JSONC": {
      "prettier": {
        "allowed": false
      }
    },
    "Python": {
      "language_servers": ["!pylsp", "pyright", "ruff"],
      "prettier": {
        "allowed": false
      }
    }
  },
  "lsp": {
    "haskell": {
      "binary": {
        "path": "/usr/local/bin/ghc"
      }
    },
    "jdtls": {
      "initialization_options": {
        "bundles": [],
        "settings": {
          "java": {
            "home": "/usr/lib/jvm/java-21-openjdk",
            "errors": {
              "incompleteClasspath": {
                "severity": "warning"
              }
            },
            "configuration": {
              "updateBuildConfiguration": "interactive",
              "maven": {
                "userSettings": null
              }
            },
            "trace": {
              "server": "verbose"
            },
            "import": {
              "gradle": {
                "enabled": true
              },
              "maven": {
                "enabled": true
              },
              "exclusions": [
                "**/node_modules/**",
                "**/.metadata/**",
                "**/archetype-resources/**",
                "**/META-INF/maven/**",
                "/**/test/**"
              ]
            },
            "jdt": {
              "ls": {
                "lombokSupport": {
                  "enabled": false // Set this to true to enable lombok support
                }
              }
            },
            "referencesCodeLens": {
              "enabled": false
            },
            "signatureHelp": {
              "enabled": false
            },
            "implementationsCodeLens": {
              "enabled": false
            },
            "format": {
              "enabled": true
            },
            "saveActions": {
              "organizeImports": false
            },
            "contentProvider": {
              "preferred": null
            },
            "autobuild": {
              "enabled": false
            },
            "completion": {
              "favoriteStaticMembers": [
                "org.junit.Assert.*",
                "org.junit.Assume.*",
                "org.junit.jupiter.api.Assertions.*",
                "org.junit.jupiter.api.Assumptions.*",
                "org.junit.jupiter.api.DynamicContainer.*",
                "org.junit.jupiter.api.DynamicTest.*"
              ],
              "importOrder": ["java", "javax", "com", "org"]
            }
          }
        }
      }
    }
  }
}
