// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "disable_ai": false,
  "formatter": "prettier",
  "ssh_connections": [
    {
      "host": "github.com",
      "projects": [],
    },
  ],
  "title_bar": {
    "show_branch_icon": true,
  },
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle",
    "copilot": {
      "proxy": null,
      "proxy_no_verify": null,
    },
    "enabled_in_text_threads": false,
  },
  "icon_theme": "Catppuccin Latte",
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "ui_font_family": "Zed Plex Mono",
  "buffer_font_family": "Zed Plex Mono",
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Mocha",
  },
  "autosave": "on_focus_change",
  "format_on_save": "off",
  "enable_language_server": true,
  "completions": {
    "enabled": false,
  },
  "soft_wrap": "editor_width",
  "inlay_hints": {
    "enabled": true,
    "trigger_chars": ["."],
  },
  "show_edit_predictions": false,
  "languages": {
    "Dockerfile": {
      "prettier": {
        "allowed": false,
      },
    },
    "Plain Text": {
      "prettier": {
        "allowed": false,
      },
    },
    "Diff": {
      "prettier": {
        "allowed": false,
      },
    },
    "Markdown": {
      "format_on_save": "off",
      "prettier": {
        "allowed": false,
      },
    },
    "JSONC": {
      "prettier": {
        "allowed": false,
      },
    },
    "JSON": {
      "prettier": {
        "allowed": false,
      },
    },
    "SQL": {
      "prettier": {
        "allowed": false,
      },
    },
    "Python": {
      "language_servers": ["pyright"],
      "prettier": {
        "allowed": false,
      },
    },
    "TypeScript": {
      "language_servers": ["typescript-language-server", "!vtsls", "..."],
      "formatter": [
        {
          "code_action": "source.fixAll.eslint",
        },
        {
          "external": {
            "command": "npx",
            "arguments": ["prettier", "--stdin-filepath", "{buffer_path}"],
          },
        },
      ],
    },
  },
  "lsp": {
    "texlab": {
      "settings": {
        "texlab": {
          "latexindent": { "modifyLineBreaks": true },
          "build": {
            "onSave": true,
            "executable": "lualatex",
          }
        }
      }
    },
    "haskell": {
      "binary": {
        "path": "/usr/local/bin/ghc",
      },
    },
    "jdtls": {
      "initialization_options": {
        "bundles": [],
        "settings": {
          "java": {
            "home": "/usr/lib/jvm/java-17-openjdk",
            "errors": {
              "incompleteClasspath": {
                "severity": "warning",
              },
            },
            "configuration": {
              "updateBuildConfiguration": "interactive",
              "maven": {
                "userSettings": null,
              },
            },
            "trace": {
              "server": "verbose",
            },
            "import": {
              "gradle": {
                "enabled": true,
              },
              "maven": {
                "enabled": true,
              },
              "exclusions": [
                "**/node_modules/**",
                "**/.metadata/**",
                "**/archetype-resources/**",
                "**/META-INF/maven/**",
                "/**/test/**",
              ],
            },
            "jdt": {
              "ls": {
                "lombokSupport": {
                  "enabled": false, // Set this to true to enable lombok support
                },
              },
            },
            "referencesCodeLens": {
              "enabled": false,
            },
            "signatureHelp": {
              "enabled": false,
            },
            "implementationsCodeLens": {
              "enabled": false,
            },
            "format": {
              "enabled": true,
            },
            "saveActions": {
              "organizeImports": false,
            },
            "contentProvider": {
              "preferred": null,
            },
            "autobuild": {
              "enabled": false,
            },
            "completion": {
              "favoriteStaticMembers": [
                "org.junit.Assert.*",
                "org.junit.Assume.*",
                "org.junit.jupiter.api.Assertions.*",
                "org.junit.jupiter.api.Assumptions.*",
                "org.junit.jupiter.api.DynamicContainer.*",
                "org.junit.jupiter.api.DynamicTest.*",
              ],
              "importOrder": ["java", "javax", "com", "org"],
            },
          },
        },
      },
    },
    "basedpyright": {
      "settings": {
        "basedpyright.analysis": {
          "diagnosticMode": "workspace",
          "inlayHints.callArgumentNames": false,
        },
      },
    },
  },
}
